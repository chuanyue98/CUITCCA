OPENAI_API_KEY=
OPENAI_API_BASE=
# OpenAI-compatible chat model name. Defaults to a SenseNova free-tier model
# (https://token.sensenova.cn/v1) if left unset.
OPENAI_MODEL=
# API key for managing indexes and system settings (manage endpoints)
CUITCCA_API_KEY=
# Whether to enable Secure flag on session cookies (True/False)
COOKIE_SECURE=False
# Session cookie max age in seconds (default 86400 = 24h)
COOKIE_MAX_AGE=86400
# Enable verbose logging (True/False)
VERBOSE=False
INDEX_SAVE_DIRECTORY='../../data/indexes/'
LOAD_PATH='../../data/temp/'
SAVE_PATH='../../data/upload_files'
FEEDBACK_PATH='../../feedback/'
LOG_PATH='../../log/'
FILE_PATH='../../data/export/'
# ChromaDB persistence directory (relative to backend/app)
CHROMA_DB_PATH='../../data/chroma_db/'
# Comma-separated list of allowed CORS origins (default: localhost)
CORS_ORIGINS=
# Host to bind the server (default: 0.0.0.0)
HOST=0.0.0.0
# Port for the server (default: 8522)
PORT=8522
