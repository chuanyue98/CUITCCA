OPENAI_API_KEY=
OPENAI_API_BASE=
# OpenAI-compatible chat model name. Defaults to a SenseNova free-tier model
# (https://token.sensenova.cn/v1) if left unset.
OPENAI_MODEL=
# API key for managing indexes and system settings (manage endpoints)
CUITCCA_API_KEY=
# Whether to enable Secure flag on session cookies (True/False)
COOKIE_SECURE=False
# Session cookie max age in seconds (default 86400 = 24h)
COOKIE_MAX_AGE=86400
# Enable verbose logging (True/False)
VERBOSE=False
INDEX_SAVE_DIRECTORY='../../data/indexes/'
LOAD_PATH='../../data/temp/'
SAVE_PATH='../../data/upload_files'
FEEDBACK_PATH='../../feedback/'
LOG_PATH='../../log/'
FILE_PATH='../../data/export/'
# ChromaDB persistence directory (relative to backend/app)
CHROMA_DB_PATH='../../data/chroma_db/'
# Comma-separated list of allowed CORS origins (default: localhost)
CORS_ORIGINS=
# Host to bind the server (default: 0.0.0.0)
HOST=0.0.0.0
# Port for the server (default: 8522)
PORT=8522

# Retrieval top_k (see evals/README.md for tuning guidance)
SIMILARITY_TOP_K=5
QUERY_ENDPOINT_TOP_K=2
MULTI_INDEX_FALLBACK_TOP_K=3
# Hybrid retrieval (BM25 + dense, RRF fusion). Default True — validated with
# evals/run_hybrid_eval.py (hit@1 +10pp, MRR +0.04, ~2ms latency cost).
HYBRID_RETRIEVAL_ENABLED=True
# Conditional cross-encoder rerank. Default True — validated with
# evals/run_rerank_eval.py and run_hybrid_eval.py (hit@1 +15pp, MRR +0.06,
# ~660ms latency cost on CPU, only paid when top1 confidence is low).
RERANK_ENABLED=True
RERANK_RECALL_K=20
RERANK_TOP_N=5
RERANK_SCORE_THRESHOLD=0.75
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
